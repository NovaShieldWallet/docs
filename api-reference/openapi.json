{
  "openapi": "3.0.3",
  "info": {
    "title": "NovaShield Security API",
    "description": "Solana security scanner. Check tokens for rug pulls, detect phishing sites, and simulate transactions before signing.",
    "version": "2.0.0",
    "contact": {
      "name": "NovaShield",
      "url": "https://novashield.space"
    }
  },
  "servers": [
    {
      "url": "https://secure.novashield.space",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:3005",
      "description": "Local Development"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health check endpoints"
    },
    {
      "name": "Token Security",
      "description": "Check Solana tokens for rug pulls and scams"
    },
    {
      "name": "Phishing Detection",
      "description": "Detect fake websites and phishing attempts"
    },
    {
      "name": "Transaction Security",
      "description": "Simulate transactions before signing to see what they'll do"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Check if the API service is running",
        "operationId": "healthCheck",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "example": {
                  "status": "healthy",
                  "service": "Nova Security API",
                  "timestamp": "2025-11-24T09:00:00.000Z",
                  "version": "1.0.0"
                }
              }
            }
          }
        }
      }
    },
    "/api/token/security": {
      "post": {
        "tags": ["Token Security"],
        "summary": "Check token security",
        "description": "Check if a Solana token is a scam or rug pull",
        "operationId": "checkTokenSecurity",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
            "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              },
              "example": {
                "contractAddress": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token security data retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenSecurityResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/token/analyze": {
      "post": {
        "tags": ["Token Security"],
        "summary": "Analyze token",
        "description": "Get detailed security analysis for a Solana token",
        "operationId": "analyzeToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              },
              "example": {
                "contractAddress": "HrPpKj6BPmCH4HmLiNCmJ7HiFmv8CYiM7qRmnqWipump"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token analysis with full RugCheck report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenAnalyzeResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
            }
          }
        }
      },
    "/api/token/comprehensive": {
      "post": {
        "tags": ["Token Security"],
        "summary": "Comprehensive token report",
        "description": "Get comprehensive security report with risks, warnings, holders, and markets",
        "operationId": "comprehensiveTokenReport",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              },
              "example": {
                "contractAddress": "HrPpKj6BPmCH4HmLiNCmJ7HiFmv8CYiM7qRmnqWipump"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comprehensive token report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComprehensiveTokenResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/token/rug-check": {
      "post": {
        "tags": ["Token Security"],
        "summary": "Rug pull detection (RECOMMENDED)",
        "description": "Fast rug pull detection with clear verdict. Best for pre-trade checks.",
        "operationId": "rugPullCheck",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              },
              "examples": {
                "scam": {
                  "summary": "Scam Token",
                  "value": {
                    "contractAddress": "HrPpKj6BPmCH4HmLiNCmJ7HiFmv8CYiM7qRmnqWipump"
                  }
                },
                "usdc": {
                  "summary": "USDC (Safe)",
                  "value": {
                    "contractAddress": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rug pull risk assessment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RugCheckResponse"
                },
                "examples": {
                  "critical": {
                    "summary": "Critical Risk Detected",
                    "value": {
                      "success": true,
                      "data": {
                        "contractAddress": "HrPpKj6BPmCH4HmLiNCmJ7HiFmv8CYiM7qRmnqWipump",
                        "chain": "solana",
                        "rugPullRisk": {
                          "score": 100,
                          "level": "CRITICAL",
                          "verdict": "🚨 EXTREME RUG PULL RISK - DO NOT BUY!",
                          "canTrade": false,
                          "isHoneypot": false
                        },
                        "risks": [],
                        "warnings": [],
                        "tokenMetrics": {
                          "holderCount": 5,
                          "name": "Present Coin",
                          "symbol": "Present",
                          "freezeAuthority": "None",
                          "mintAuthority": "None",
                          "liquidity": 0,
                          "marketCap": 0
                        },
                        "source": "RugCheck.xyz",
                        "rugCheckScore": 1
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/api/phishing/check": {
      "post": {
        "tags": ["Phishing Detection"],
        "summary": "Check for phishing",
        "description": "Check if a URL is fake or trying to steal your wallet. Catches typosquatting (like cpump.fun vs pump.fun).",
        "operationId": "checkPhishing",
        "requestBody": {
            "required": true,
          "content": {
            "application/json": {
            "schema": {
                "$ref": "#/components/schemas/PhishingRequest"
              },
              "examples": {
                "phishing": {
                  "summary": "Phishing Site (cpump.fun)",
                  "value": {
                    "url": "https://cpump.fun"
                  }
                },
                "legitimate": {
                  "summary": "Legitimate Site",
                  "value": {
                    "url": "https://pump.fun"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phishing check result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhishingResponse"
                },
                "examples": {
                  "phishing_detected": {
                    "summary": "Phishing Detected",
                    "value": {
                      "success": true,
                      "data": {
                        "url": "https://cpump.fun",
                        "isPhishing": true,
                        "confidence": 95,
                        "riskLevel": "CRITICAL",
                        "verdict": "🚨 PHISHING SITE DETECTED - DO NOT CONNECT!",
                        "reasons": [
                          "Suspicious similarity to pump.fun (typosquatting attempt)",
                          "AI detected phishing"
                        ],
                        "similarTo": "pump.fun",
                        "recommendations": [
                          "DO NOT connect your wallet to this site",
                          "This appears to be impersonating a legitimate site"
                        ]
                      }
                    }
                  },
                  "safe_site": {
                    "summary": "Safe Site",
                    "value": {
                      "success": true,
                      "data": {
                        "url": "https://pump.fun",
                        "isPhishing": false,
                        "confidence": 50,
                        "riskLevel": "LOW",
                        "verdict": "⚠️ Unknown site - Proceed with caution",
                        "reasons": ["No phishing indicators found"],
                        "recommendations": [
                          "Cannot verify legitimacy with high confidence",
                          "Only connect if you trust this source"
                        ]
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
        }
      }
    }
  },
    "/api/simulate-transaction": {
      "post": {
        "tags": ["Transaction Security"],
        "summary": "Simulate Solana transaction",
        "description": "Simulate a Solana transaction before signing to see what it will do and assess risks",
        "operationId": "simulateTransaction",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SimulateTransactionRequest"
              },
              "example": {
                "transaction": "BASE64_ENCODED_TRANSACTION_HERE",
                "signerPublicKey": "7xKXtg2CW87d97TXJSDpbD5jBkheTqA83TZRuJosgAsU"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction simulation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SimulateTransactionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Optional Bearer token authentication (not currently required)"
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "healthy"
          },
          "service": {
            "type": "string",
            "example": "Nova Security API"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "version": {
            "type": "string",
            "example": "1.0.0"
          }
        }
      },
      "TokenRequest": {
        "type": "object",
        "required": ["contractAddress"],
        "properties": {
          "contractAddress": {
            "type": "string",
            "description": "Solana token mint address",
            "example": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
          }
        }
      },
      "PhishingRequest": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to check for phishing",
            "example": "https://pump.fun"
          }
        }
      },
      "SimulateTransactionRequest": {
        "type": "object",
        "required": ["transaction", "signerPublicKey"],
        "properties": {
          "transaction": {
            "type": "string",
            "description": "Base64-encoded Solana transaction",
            "example": "AQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAACAAQABAgMEBQ..."
          },
          "signerPublicKey": {
            "type": "string",
            "description": "Public key of the transaction signer",
            "example": "7xKXtg2CW87d97TXJSDpbD5jBkheTqA83TZRuJosgAsU"
          }
        }
      },
      "RugPullRisk": {
        "type": "object",
        "properties": {
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Rug pull risk score (0=safe, 100=critical)",
            "example": 100
          },
          "level": {
            "type": "string",
            "enum": ["SAFE", "LOW", "MEDIUM", "HIGH", "CRITICAL"],
            "description": "Risk level classification",
            "example": "CRITICAL"
          },
          "verdict": {
            "type": "string",
            "description": "Human-readable verdict",
            "example": "🚨 EXTREME RUG PULL RISK - DO NOT BUY!"
          },
          "canTrade": {
            "type": "boolean",
            "description": "Whether trading should be allowed",
            "example": false
          },
          "isHoneypot": {
            "type": "boolean",
            "description": "Whether token is a honeypot",
            "example": false
          }
        }
      },
      "TokenMetrics": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Present Coin"
          },
          "symbol": {
            "type": "string",
            "example": "Present"
          },
          "holderCount": {
            "type": "integer",
            "example": 5
          },
          "liquidity": {
            "type": "number",
            "example": 0
          },
          "marketCap": {
            "type": "number",
            "example": 0
          },
          "freezeAuthority": {
            "type": "string",
            "nullable": true,
            "example": "None"
          },
          "mintAuthority": {
            "type": "string",
            "nullable": true,
            "example": "None"
          }
        }
      },
      "TokenSecurityResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "contractAddress": {
                "type": "string"
              },
              "chain": {
                "type": "string",
                "example": "solana"
              },
              "rugPullRisk": {
                "$ref": "#/components/schemas/RugPullRisk"
              },
              "tokenMetrics": {
                "$ref": "#/components/schemas/TokenMetrics"
              },
              "rugCheckScore": {
                "type": "integer",
                "description": "RugCheck score (0-1000, higher=better)",
                "example": 1
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TokenAnalyzeResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "contractAddress": {
                "type": "string"
              },
              "chain": {
                "type": "string",
                "example": "solana"
              },
              "rugPullRisk": {
                "$ref": "#/components/schemas/RugPullRisk"
              },
              "tokenMetrics": {
                "type": "object"
              },
              "rugCheckReport": {
                "type": "object",
                "description": "Full RugCheck.xyz report"
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ComprehensiveTokenResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "contractAddress": {
                "type": "string"
              },
              "chain": {
                "type": "string",
                "example": "solana"
              },
              "rugPullRisk": {
                "$ref": "#/components/schemas/RugPullRisk"
              },
              "risks": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": ["🚨 High concentration risk"]
              },
              "warnings": {
                "type": "array",
                "items": {
            "type": "string"
                },
                "example": ["⚠️ Pump.fun token"]
              },
              "tokenMetrics": {
                "$ref": "#/components/schemas/TokenMetrics"
              },
              "markets": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "topHolders": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "fullReport": {
                "type": "object"
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RugCheckResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "contractAddress": {
                "type": "string"
              },
              "chain": {
                "type": "string",
                "example": "solana"
              },
              "rugPullRisk": {
                "$ref": "#/components/schemas/RugPullRisk"
              },
              "risks": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "warnings": {
                "type": "array",
                "items": {
            "type": "string"
                }
              },
              "tokenMetrics": {
                "$ref": "#/components/schemas/TokenMetrics"
              },
              "rugCheckScore": {
                "type": "integer"
              },
              "rawReport": {
                "type": "object"
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PhishingResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "example": "https://cpump.fun"
              },
              "isPhishing": {
                "type": "boolean",
                "description": "Whether site is phishing",
                "example": true
              },
              "confidence": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100,
                "description": "Confidence level (0-100)",
                "example": 95
              },
              "riskLevel": {
                "type": "string",
                "enum": ["SAFE", "LOW", "MEDIUM", "HIGH", "CRITICAL"],
                "example": "CRITICAL"
              },
              "verdict": {
                "type": "string",
                "example": "🚨 PHISHING SITE DETECTED - DO NOT CONNECT!"
              },
              "reasons": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "Suspicious similarity to pump.fun (typosquatting attempt)"
                ]
              },
              "similarTo": {
                "type": "string",
                "nullable": true,
                "description": "Legitimate domain this may be impersonating",
                "example": "pump.fun"
              },
              "recommendations": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "DO NOT connect your wallet to this site"
                ]
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SimulateTransactionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "simulation": {
                "type": "object",
                "properties": {
                  "success": {
                    "type": "boolean",
                    "description": "Whether transaction will succeed"
                  },
                  "logs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "risks": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": ["🚨 Attempting to transfer ALL tokens"]
                  },
                  "warnings": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": ["⚠️ High slippage detected"]
                  }
                }
              },
              "transaction": {
                "type": "object",
                "properties": {
                  "instructions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "program": {
                          "type": "string",
                          "example": "Token Program"
                        },
                        "programId": {
                          "type": "string",
                          "example": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA"
                        },
                        "accountsInvolved": {
                          "type": "integer",
                          "example": 3
                        }
                      }
                    }
                  },
                  "totalInstructions": {
                    "type": "integer",
                    "example": 1
                  }
                }
              },
              "riskAssessment": {
                "type": "object",
                "properties": {
                  "score": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100,
                    "example": 10
                  },
                  "level": {
                    "type": "string",
                    "enum": ["SAFE", "LOW", "MEDIUM", "HIGH", "CRITICAL"],
                    "example": "SAFE"
                  },
                  "verdict": {
                    "type": "string",
                    "example": "✅ Transaction appears safe"
                  }
                }
              },
              "recommendations": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "✅ Transaction appears safe to sign",
                  "Always verify recipient addresses"
                ]
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "description": "Error message",
            "example": "Missing required field: contractAddress"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": "Missing required field: contractAddress",
              "timestamp": "2025-11-24T09:00:00.000Z"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": "Token data not found",
              "timestamp": "2025-11-24T09:00:00.000Z"
            }
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": "Internal server error",
              "timestamp": "2025-11-24T09:00:00.000Z"
            }
          }
        }
      }
    }
  }
}
